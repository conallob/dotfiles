#!/bin/bash
{{- /* chezmoi modify script: merges MCP servers into ~/.claude.json */ -}}
set -euo pipefail

MCP_SERVERS=$(mktemp)
trap 'rm -f "$MCP_SERVERS"' EXIT

cat > "$MCP_SERVERS" << 'MCPEOF'
{
{{- includeTemplate "dot_claude/mcp-servers-personal.json.tmpl" . | indent 2 }}
{{- if eq .chezmoi.username "cobrien" }},
{{ includeTemplate "dot_claude/mcp-servers-work.json.tmpl" . | indent 2 }}
{{- end }}
}
MCPEOF

INPUT=$(cat)
[ -z "$INPUT" ] && INPUT="{}"
echo "$INPUT" | jq --slurpfile servers "$MCP_SERVERS" '.mcpServers = ((.mcpServers // {}) + $servers[0])'
