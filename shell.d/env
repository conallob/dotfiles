# vim: ft=sh

#
# Path should already be set in ~/.zshrc
#

# Useful variables for understanding the machine specific configs
CONFIGS="$(chezmoi source-path)/shell.d"
export CONFIGS
MYHOSTNAME="$(hostname -s)"
export MYHOSTNAME

export EDITOR="vim"
export PAGER="less"

# rsync flags for gigabit transfers per https://gist.github.com/KartikTalwar/4393116
export RSYNC_FLAGS="-Pvar --numeric-ids --progress -e 'ssh -T -c aes128-gcm@openssh.com -o Compression=no -x'"

export LANG=en_IE.UTF-8
export LC_CTYPE=en_IE.UTF-8
export LC_MESSAGES=C

# Disable ssh-agent config
#
# ssh-agent+screen magic
# source "${CONFIGS}/env.ssh-agent"

# Let's make /tmp/conall
if [ -d /tmp/conall ]
then
   /usr/bin/true
else
   mkdir /tmp/conall >/dev/null 2>&1
   chmod 700 /tmp/conall
fi

# Enable platform env settings
if [ -e "${CONFIGS}/env.$(uname -s)" ];
then
  . "${CONFIGS}/env.$(uname -s)"
fi

# Enable host specific env settings
if [ -e "${CONFIGS}/env.$(hostname -s)" ];
then
  . "${CONFIGS}/env.$(hostname -s)"
fi
