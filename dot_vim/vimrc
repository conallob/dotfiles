" ============================================================================
" ifttt-lint Configuration
" ============================================================================
" Validates LINT.IfChange / LINT.ThenChange cross-file sync markers.
" Ensures that when a marked block changes, its linked counterpart also changes.
" Install: cargo install ifttt-lint  (see github.com/simonepri/ifttt-lint)
"
" Output format: file:line: severity: message
" Only active when 'ifttt-lint' is found in PATH.
if executable('ifttt-lint')
  function! s:IftttLintHandler(buffer, lines) abort
    let l:pattern = '\v^\S+:(\d+): (error|warning): (.+)$'
    let l:output = []
    for l:line in a:lines
      let l:match = matchlist(l:line, l:pattern)
      if len(l:match) > 0
        call add(l:output, {
        \  'lnum': str2nr(l:match[1]),
        \  'type': l:match[2] ==# 'error' ? 'E' : 'W',
        \  'text': l:match[3],
        \ })
      endif
    endfor
    return l:output
  endfunction

  " Register the linter definition for each supported filetype.
  for s:ft in ['go', 'python', 'sh', 'yaml', 'yaml.ansible',
  \            'proto', 'bzl', 'markdown', 'typescript', 'rust', 'helm']
    call ale#linter#Define(s:ft, {
    \  'name':       'ifttt_lint',
    \  'executable': 'ifttt-lint',
    \  'command':    'ifttt-lint --format plain %s',
    \  'callback':   function('s:IftttLintHandler'),
    \ })
  endfor
  unlet s:ft

  " Add ifttt_lint to the explicit linters list for each registered filetype.
  " (g:ale_linters_explicit = 1 means linters must be listed to run.)
  for s:ft in keys(g:ale_linters)
    if index(['go', 'python', 'sh', 'yaml', 'yaml.ansible',
    \         'proto', 'bzl', 'markdown'], s:ft) >= 0
      call add(g:ale_linters[s:ft], 'ifttt_lint')
    endif
  endfor
  unlet s:ft
endif

