{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": false,
  "enabledPlugins": {
    {{- /* Github API plugin */}}
    "github@claude-plugins-official": true,
    {{- /* LSP Servers */}}
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    {{- /* Git Commit Commands */}}
    "commit-commands@claude-plugins-official": true,
    {{- /* Obsidian Skills */}}
    "obsidian@obsidian-skills": true
  },
{{- if eq .chezmoi.username "cobrien" }}
  "env": {
    {{- /* GitLab API token from work 1Password account */}}
    "GITLAB_TOKEN": "{{ (onepasswordDetailsFields "zvmzgcfpmw33ttzrw4ureqxtim" "" "FUJ74MTVQVCN5DXVK4PSF5HKU4").credential.value }}"
  },
{{- end }}
  "hooks": {
    {{- /* Native system notifications when Claude is waiting for input */}}
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            {{- /* macOS native notification with Claude app icon */}}
            "command": "terminal-notifier -message \"Claude has completed the task and is awaiting your input\" -title \"Claude Code\" -sender com.anthropic.claudefordesktop"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            {{- /* Alert when Claude needs permission with Claude app icon */}}
            "command": "terminal-notifier -message \"Claude needs your permission to proceed\" -title \"Claude Code\" -sender com.anthropic.claudefordesktop"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            {{- /* Terminal bell when Claude finishes responding */}}
            "command": "printf '\\a'"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    {{- /* Re-inject CLAUDE.md after context compaction to restore critical instructions */}}
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Context compacted. Re-read ~/.claude/CLAUDE.md and the project CLAUDE.md (if present) to restore critical instructions before continuing.'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
