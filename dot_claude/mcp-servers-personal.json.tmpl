{{- /* Personal and Third-party MCP Servers */ -}}
"obsidian-mcp-tools": {
  "command": "/Users/{{- .chezmoi.username -}}/Documents/Multiverse/.obsidian/plugins/mcp-tools/bin/mcp-server",
  "env": {
    "OBSIDIAN_API_KEY": "{{- (onepasswordDetailsFields "xe6ncd3wlggzxt6lq7zv3mduly").credential.value }}"
  }
},
"omnifocus": {
  "command": "/opt/homebrew/bin/mcp-omnifocus",
  "args": [
    "-scripts", "/opt/homebrew/share/mcp-omnifocus",
    "-cache-ttl", "60"
  ]
},
"ssh-wingman": {
  "command": "/opt/homebrew/bin/mcp-ssh-wingman",
  "args": ["--session", "mcp-wingman"]
},
"toshl": {
  "command": "/opt/homebrew/bin/mcp-toshl",
  "env": {
    "TOSHL_TOKEN": "{{- (onepasswordDetailsFields "toshl-api-token").credential.value }}"
  }
},
"jetkvm": {
  "command": "/opt/homebrew/bin/mcp-jetkvm",
  "env": {
    "JETKVM_HOST": "{{- (onepasswordDetailsFields "obmmyfye6pntjru4uv5a36scwq").URL.value }}",
    "JETKVM_PASSWORD": "{{- (onepasswordDetailsFields "obmmyfye6pntjru4uv5a36scwq").credential.value }}"
  }
}
